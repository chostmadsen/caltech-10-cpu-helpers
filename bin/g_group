set -e
if [ $# -lt 2 ]; then
    echo "usage: ./g_group <instruction file.csv> <group dir>"
    exit 1
fi

instr="$1"
dir="$2"

rm -f "$dir"/out_*.txt
for f in "$dir"/*.txt; do
    base=$(basename "$f" .txt)
    out="$dir/out_$base.txt"
    echo "./bin/group $instr $f $out"
    ./bin/group "$instr" "$f" "$out"
done
